{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-coding-benchmarks.local/schemas/suite.schema.json",
  "title": "BenchmarkSuite",
  "description": "Suite YAML contract: named task list with default repetitions.",
  "type": "object",
  "required": ["name", "repetitions", "tasks"],
  "additionalProperties": true,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "repetitions": {
      "type": "integer",
      "minimum": 1
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "Stable taskId referenced by the suite"
      }
    }
  }
}
