{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-coding-benchmarks.local/schemas/trial.schema.json",
  "title": "Trial",
  "description": "Single trial execution record within a campaign. Written by writeTrialResult to results/<trialId>/result.json. Always includes schemaVersion and writtenAt. resolvedModel is never invented from requestedModel; when unavailable, resolvedModel is null and resolvedModelAvailable is false.",
  "type": "object",
  "required": [
    "id",
    "experimentId",
    "arm",
    "taskId",
    "repetition",
    "scheduleSeed",
    "invocationPath",
    "requestedModel",
    "state",
    "schemaVersion",
    "writtenAt"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "experimentId": {
      "type": "string",
      "minLength": 1
    },
    "arm": {
      "type": "string",
      "minLength": 1,
      "description": "Arm name from the experiment"
    },
    "provider": {
      "type": "string"
    },
    "taskId": {
      "type": "string",
      "minLength": 1
    },
    "repetition": {
      "type": "integer",
      "minimum": 1
    },
    "scheduleSeed": {
      "type": ["integer", "string"]
    },
    "invocationPath": {
      "type": "string",
      "enum": ["poetic-adapter", "native-cli", "poetic-system"]
    },
    "requestedModel": {
      "type": ["string", "null"],
      "minLength": 1,
      "description": "Model id requested on the arm; null only when arm had no model (writeTrialResult default)"
    },
    "resolvedModel": {
      "type": ["string", "null"],
      "description": "Model id actually used after resolution, if known; never invented from requestedModel"
    },
    "resolvedModelAvailable": {
      "type": "boolean",
      "description": "True only when resolvedModel was obtained from invoker/adapter evidence"
    },
    "resolvedModelSource": {
      "type": "string",
      "description": "Evidence source for resolvedModel (e.g. model.resolved.value, invoker-explicit, unavailable, absent)"
    },
    "postureFingerprint": {
      "type": ["string", "null"],
      "pattern": "^[a-f0-9]{64}$"
    },
    "state": {
      "type": "string",
      "enum": ["pending", "running", "completed", "failed", "skipped"]
    },
    "classification": {
      "type": ["string", "null"],
      "enum": ["PASS", "FAIL", "NO_OP", "INFRA_FAIL", "TIMEOUT", null]
    },
    "classificationReason": {
      "type": ["string", "null"]
    },
    "hashes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "fixtureHash": { "type": "string" },
        "baselineCommit": { "type": "string" },
        "promptHash": { "type": "string" },
        "workspaceHash": { "type": "string" }
      }
    },
    "digests": {
      "type": "object",
      "additionalProperties": false,
      "description": "Evidence binding digests: exact raw stdout/stderr/output bytes, artifact tree, fixture tree, and final-record result envelope. rawEvidenceUnavailable marks infra records without provider raw.",
      "properties": {
        "resultDigest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "artifactDigest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "fixtureDigest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "rawOutputDigest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "rawStdoutSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "rawStderrSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "rawOutputFileSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "rawEvidenceUnavailable": {
          "type": "boolean",
          "description": "True when INFRA_FAIL path stored no raw provider artifacts (unavailable for report)"
        }
      }
    },
    "exitCode": {
      "type": ["integer", "null"],
      "description": "Invoker process exit code; null when the process never exited cleanly"
    },
    "executionRoot": {
      "type": ["string", "null"],
      "description": "External execution root for provider workspaces (outside campaign tree)"
    },
    "gateResults": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "description": "Gate evidence after stripGatePreviews (no stdout/stderr previews)"
      }
    },
    "changedFileCount": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "startedAt": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "finishedAt": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "durationMs": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "error": {
      "type": ["string", "null"]
    },
    "workspaceDir": {
      "type": ["string", "null"]
    },
    "artifactDir": {
      "type": ["string", "null"]
    },
    "schemaVersion": {
      "type": "integer",
      "const": 1,
      "description": "Always stamped by writeTrialResult from SCHEMA_VERSION"
    },
    "writtenAt": {
      "type": "string",
      "format": "date-time",
      "description": "Always stamped by writeTrialResult at write time"
    }
  }
}
