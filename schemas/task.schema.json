{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-coding-benchmarks.local/schemas/task.schema.json",
  "title": "BenchmarkTask",
  "description": "Task YAML contract reflecting benchmarks/cli-comparison/tasks/**/*.yaml",
  "type": "object",
  "required": [
    "taskId",
    "type",
    "description",
    "expectedOutcome",
    "eligibilityGates"
  ],
  "additionalProperties": true,
  "properties": {
    "taskId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(greenfield|brownfield)-.+"
    },
    "type": {
      "type": "string",
      "enum": ["greenfield", "brownfield"]
    },
    "codeType": {
      "type": "string",
      "description": "e.g. from-scratch, starter-code, existing-codebase"
    },
    "category": {
      "type": "string",
      "description": "e.g. feature, bugfix, refactor, migration"
    },
    "language": {
      "type": "string"
    },
    "targetLanguage": {
      "type": "string"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "complexity": {
      "type": "string"
    },
    "expectedOutcome": {
      "type": "object",
      "required": ["mustHave"],
      "additionalProperties": true,
      "properties": {
        "mustHave": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/outcomeItem" }
        },
        "niceToHave": {
          "type": "array",
          "items": { "$ref": "#/definitions/outcomeItem" }
        },
        "successCriteria": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "eligibilityGates": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/eligibilityGate" }
    },
    "fixturePath": {
      "type": "string",
      "minLength": 1,
      "description": "Relative fixture directory name under suite fixtures/"
    },
    "fixture": {
      "type": "object",
      "additionalProperties": true
    },
    "scoring": {
      "type": "object",
      "additionalProperties": true
    },
    "toolEvidencePolicy": {
      "type": "object",
      "additionalProperties": true
    },
    "networkPolicy": {
      "type": "object",
      "additionalProperties": true
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "estimatedMinutes": {
      "type": "number",
      "minimum": 0
    }
  },
  "definitions": {
    "outcomeItem": {
      "type": "object",
      "required": ["id", "description"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "substantiation": { "type": "string" },
        "artifactRef": { "type": "string" }
      }
    },
    "eligibilityGate": {
      "type": "object",
      "required": ["gate", "order"],
      "additionalProperties": true,
      "properties": {
        "gate": {
          "type": "string",
          "minLength": 1,
          "description": "Gate name: baseline-diff, install, lint, tests, oracle, requirements, etc."
        },
        "check": {
          "type": "string"
        },
        "command": {
          "type": "string",
          "description": "Exact literal shell command string; must not be rewritten by the harness"
        },
        "expectedExitCode": {
          "type": "integer",
          "description": "Defaults to 0 when omitted at load time"
        },
        "order": {
          "type": "integer",
          "minimum": 1
        },
        "required": {
          "type": "boolean",
          "default": true
        },
        "oraclePath": {
          "type": "string",
          "description": "Optional path to oracle script relative to suite oracles/"
        }
      }
    }
  }
}
